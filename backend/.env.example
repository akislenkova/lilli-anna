# Copy this file to .env and fill in the values before running locally.
# Never commit .env — it is listed in .gitignore.

# Database
DATABASE_URL=postgresql://anilla:anilla@localhost:5432/anilla

# JWT signing key — generate with: openssl rand -hex 32
SECRET_KEY=replace-me-with-openssl-rand-hex-32-output

# AES-256 key for encrypting PHI fields (base64-encoded 32-byte key)
# Generate with: python -c "import secrets, base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
ENCRYPTION_KEY=replace-me-with-generated-key

# CORS (comma-separated origins)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# External service stubs (leave as-is for local dev)
EHR_BASE_URL=http://localhost:8081/ehr
EHR_API_KEY=
TRANSCRIPTION_SERVICE_URL=http://localhost:8082/transcribe
