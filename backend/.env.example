# Copy this file to .env and fill in the values before running locally.
# Never commit .env — it is listed in .gitignore.

# development | staging | production
# Railway production: set to production (disables /docs, OpenAPI, and auto create_all).
ENVIRONMENT=development

# Local only: allow POST /auth/register to create physician/nurse/scheduler/admin.
# Railway production: leave false (default) or omit — only patient self-registration is allowed.
ALLOW_STAFF_SELF_REGISTRATION=true

# Database
DATABASE_URL=postgresql://anilla:anilla@localhost:5432/anilla

# JWT signing key — generate with: openssl rand -hex 32 (use 32+ chars in production)
SECRET_KEY=replace-me-with-openssl-rand-hex-32-output

# AES-256 key for encrypting PHI fields (base64-encoded 32-byte key)
# Generate with: python -c "import secrets, base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
ENCRYPTION_KEY=replace-me-with-generated-key

# Browser origins allowed to send credentials to the API.
# Vercel: include your production URL and each preview URL pattern you use (origins are exact; wildcards are not supported).
# FRONTEND_URL is auto-appended to this list if missing.
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
FRONTEND_URL=http://localhost:5173

# External service stubs (leave as-is for local dev)
EHR_BASE_URL=http://localhost:8081/ehr
EHR_API_KEY=
TRANSCRIPTION_SERVICE_URL=http://localhost:8082/transcribe

# Epic FHIR / MyChart integration
# Register your app at https://fhir.epic.com/Developer/Apps to get a client ID.
# Epic sandbox FHIR base: https://fhir.epic.com/interconnect-fhir-oauth/api/FHIR/R4
# Set EPIC_MYCHART_BASE_URL to your organisation's MyChart root (e.g. https://mychart.yourhospital.org/MyChart)
EPIC_FHIR_BASE_URL=https://fhir.epic.com/interconnect-fhir-oauth
EPIC_CLIENT_ID=
EPIC_MYCHART_BASE_URL=https://mychart.epic.com/MyChart
